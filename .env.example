# Shared
NODE_ENV=development
APP_NAME=Vidravault
PUBLIC_APP_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# Database / queue
DATABASE_URL=postgresql://vidravault:vidravault@localhost:5432/vidravault?schema=public
REDIS_URL=redis://localhost:6379

# API
API_HOST=0.0.0.0
API_PORT=4000
WEB_ORIGIN=http://localhost:5173
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
COOKIE_SECURE=false
REQUIRE_AUTH=true
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-now
API_RATE_LIMIT_MAX=120
RETRIEVAL_RATE_LIMIT_MAX=60
MCP_RATE_LIMIT_MAX=30

# Storage
ARTIFACTS_DIR=./artifacts
EXPORTS_DIR=./exports
MAX_VIDEO_URL_LENGTH=2048

# Ingestion binaries
YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
COMMAND_TIMEOUT_SECONDS=1800
CAPTION_LANGUAGES=en,fr

# Transcription
TRANSCRIPTION_PROVIDER=mock
MLX_WHISPER_BIN=mlx_whisper
MLX_WHISPER_MODEL=mlx-community/whisper-large-v3-turbo

# Workers
QUEUE_WORKER_ENABLED=true
PIPELINE_CONCURRENCY=2
FRAME_INTERVAL_SECONDS=0

# MCP app, disabled unless explicitly set to true
MCP_ENABLED=false
MCP_MODE=stdio
MCP_API_BASE_URL=http://localhost:4000
MCP_API_TOKEN=change-me-for-local-mcp-use
