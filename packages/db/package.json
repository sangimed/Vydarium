{
  "name": "@vidravault/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "cd ../.. && packages/db/node_modules/.bin/prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate": "cd ../.. && packages/db/node_modules/.bin/prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "db:dev": "cd ../.. && packages/db/node_modules/.bin/prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:studio": "cd ../.. && packages/db/node_modules/.bin/prisma studio --schema packages/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.3"
  },
  "devDependencies": {
    "prisma": "6.19.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
